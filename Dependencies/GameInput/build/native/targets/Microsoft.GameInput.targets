<?xml version="1.0"?>
<Project ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <GameInputNativeBuildDirectory>$(MSBuildThisFileDirectory)..\..\..\native\</GameInputNativeBuildDirectory>
  </PropertyGroup>

  <ItemDefinitionGroup>
    <ClCompile>
      <PreprocessorDefinitions>USING_GAMEINPUT;%(PreprocessorDefinitions)</PreprocessorDefinitions>
      <AdditionalIncludeDirectories>$(GameInputNativeBuildDirectory)include;%(AdditionalIncludeDirectories)</AdditionalIncludeDirectories>
    </ClCompile>
  </ItemDefinitionGroup>

  <ItemDefinitionGroup>
    <!-- Default to x86 for this engine, check for x64 specifically if needed -->
    <Link Condition="'$(Platform)'=='x64'">
      <AdditionalLibraryDirectories>$(GameInputNativeBuildDirectory)lib\x64;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
    <Link Condition="'$(Platform)'=='Win32' Or '$(Platform)'=='x86'">
      <AdditionalLibraryDirectories>$(GameInputNativeBuildDirectory)lib\x86;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
    <Link Condition="'$(Platform)'=='ARM64'">
      <AdditionalLibraryDirectories>$(GameInputNativeBuildDirectory)lib\arm64;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
    <!-- Fallback for legacy builds -->
    <Link Condition="'$(Platform)'==''">
      <AdditionalLibraryDirectories>$(GameInputNativeBuildDirectory)lib\x86;%(AdditionalLibraryDirectories)</AdditionalLibraryDirectories>
    </Link>
    <Link>
      <AdditionalDependencies>%(AdditionalDependencies);GameInput.lib</AdditionalDependencies>
    </Link>
  </ItemDefinitionGroup>

</Project>
